// ===================== STATE =====================
// All data lives in these two arrays — simple, reliable
let customers = [];   // [{id, name, email, mobile}]
let callLogs = [];    // [{id, clientId, date, outcome, followup, notes, createdAt}]

let logCid = null;   // current client being logged
let histCid = null;  // current client for history modal

// Table state
let pg = 1;
const PG = 25;
let srchVal = '';
let fltVal = '';
let sortC = 'name';
let sortD = 1;

let sharedDbAvailable = false; // Maps to Firebase status for backward compatibility
let isFirebaseInitialized = false;
let firebaseSaveTimer = null;
let firebaseListener = null;

// ===================== FIREBASE CONFIG & SYNC =====================
function getFirebaseConfig() {
  // 1. Try file config
  if (window.FIREBASE_CONFIG && window.FIREBASE_CONFIG.apiKey && window.FIREBASE_CONFIG.apiKey !== "YOUR_API_KEY") {
    return window.FIREBASE_CONFIG;
  }
  // 2. Try localStorage config
  const local = localStorage.getItem('firebase_config');
  if (local) {
    try {
      return JSON.parse(local);
    } catch(e) {}
  }
  return null;
}

function initFirebase() {
  const config = getFirebaseConfig();
  if (!config) {
    sharedDbAvailable = false;
    isFirebaseInitialized = false;
    return false;
  }
  try {
    if (typeof firebase === 'undefined') {
      console.error("Firebase SDK not loaded");
      sharedDbAvailable = false;
      isFirebaseInitialized = false;
      return false;
    }

    // Detach old listener if any
    if (firebaseListener && typeof firebase !== 'undefined') {
      try { firebase.database().ref('calltrack').off('value', firebaseListener); } catch(e) {}
      firebaseListener = null;
    }

    // Delete existing app before re-initializing
    if (firebase.apps.length > 0) {
      try { firebase.app().delete(); } catch(e) {}
    }
    
    // Auto-detect missing databaseURL if projectId is present
    if (!config.databaseURL && config.projectId) {
      config.databaseURL = `https://${config.projectId}-default-rtdb.firebaseio.com`;
    }

    firebase.initializeApp(config);
    sharedDbAvailable = true;
    isFirebaseInitialized = true;
    return true;
  } catch(e) {
    console.error("Firebase init error:", e);
    sharedDbAvailable = false;
    isFirebaseInitialized = false;
    return false;
  }
}

function loadFirebaseDB() {
  if (!isFirebaseInitialized) return;
  const dbRef = firebase.database().ref('calltrack');
  
  if (firebaseListener) {
    dbRef.off('value', firebaseListener);
  }
  
  firebaseListener = dbRef.on('value', (snapshot) => {
    const d = snapshot.val();
    // Load from Firebase if it has real data
    if (d && Array.isArray(d.customers) && Array.isArray(d.calls) && d.customers.length > 0) {
      customers = d.customers;
      callLogs = d.calls;
      localStorage.setItem('calltrack_data', JSON.stringify({ customers, calls: callLogs }));
      toast('Cloud database updated', 'ok');
      renderAll();
      return;
    }
    // Firebase has no data — use local data and let save() push to cloud later
    const saved = localStorage.getItem('calltrack_data');
    if (saved) {
      try {
        const localData = JSON.parse(saved);
        if (localData.customers && localData.customers.length > 0) {
          customers = localData.customers;
          callLogs = localData.calls || [];
          renderAll();
          return;
        }
      } catch(e) {}
    }
    seedCustomers();
    renderAll();
  }, (error) => {
    console.error("Firebase read failed:", error);
    toast('Cloud sync failed. Offline mode active.', 'err');
    loadBrowserDB();
    renderAll();
  });
}

function queueFirebaseSave() {
  clearTimeout(firebaseSaveTimer);
  firebaseSaveTimer = setTimeout(saveFirebaseDBDirect, 500);
}

function saveFirebaseDBDirect() {
  if (!isFirebaseInitialized) return;
  const data = { version: 1, exportedAt: new Date().toISOString(), customers, calls: callLogs };
  firebase.database().ref('calltrack').set(data)
    .then(() => {
      // Quiet success
    })
    .catch(err => {
      console.error("Firebase write failed:", err);
      toast('Cloud save failed! Storing locally.', 'err');
    });
}

// ===================== INIT =====================
async function init() {
  // Load local data first for instant display, then sync Firebase in background
  loadBrowserDB();

  const isDbConfigured = initFirebase();
  if (isDbConfigured) {
    loadFirebaseDB();
  }

  // Wire up filter dropdown
  document.getElementById('flt').addEventListener('change', function() {
    fltVal = this.value;
    pg = 1;
    drawTable();
  });

  renderAll();
}

function loadBrowserDB() {
  const saved = localStorage.getItem('calltrack_data');
  if (saved) {
    try {
      const d = JSON.parse(saved);
      customers = d.customers || [];
      callLogs = d.calls || [];
      return;
    } catch(e) {}
  }
  seedCustomers();
}

// Built-in seed mapper
function seedCustomers() {
  customers = SEED.map((c, i) => ({ id: 'c' + i, name: c.name, email: c.email || '', mobile: String(c.mobile || '') }));
  callLogs = [];
  save();
}

// ===================== PERSIST =====================
function save() {
  localStorage.setItem('calltrack_data', JSON.stringify({ customers, calls: callLogs }));
  updateDBStatus();
  if (isFirebaseInitialized) {
    queueFirebaseSave();
  }
}

// ===================== FIREBASE SETUP UI =====================
function openFirebaseSetup() {
  const config = getFirebaseConfig();
  document.getElementById('fb-config-text').value = config ? JSON.stringify(config, null, 2) : '';
  document.getElementById('m-fbsetup').classList.add('open');
}

function saveFirebaseConfigUI() {
  let txt = document.getElementById('fb-config-text').value.trim();
  if (!txt) {
    toast('Please enter the configuration', 'err');
    return;
  }

  // Extract the first { ... } object from whatever the user pasted
  const startB = txt.indexOf('{');
  const endB = txt.lastIndexOf('}');
  if (startB === -1 || endB === -1 || endB < startB) {
    toast('❌ Could not find a { ... } object in the pasted text.', 'err');
    return;
  }
  const objStr = txt.substring(startB, endB + 1);

  // Try JSON.parse first (strict JSON with quoted keys)
  let parsed = null;
  try {
    parsed = JSON.parse(objStr);
  } catch(e) {
    // Fallback: evaluate as a JavaScript object literal
    try {
      parsed = new Function('"use strict"; return (' + objStr + ')')();
    } catch(e2) {
      console.error('Config parse failed:', e2);
    }
  }

  if (!parsed || typeof parsed !== 'object' || !parsed.apiKey) {
    toast('❌ Invalid config: missing apiKey. Paste the full object from Firebase Console > Project Settings > Your apps.', 'err');
    return;
  }

  if (!parsed.databaseURL && !parsed.projectId) {
    toast('❌ Invalid config: missing databaseURL or projectId.', 'err');
    return;
  }

  localStorage.setItem('firebase_config', JSON.stringify(parsed));
  closeM('m-fbsetup');
  toast('✅ Firebase config saved!', 'ok');

  if (initFirebase()) {
    loadFirebaseDB();
    updateDBStatus();
    // Push local data to cloud (outside listener to avoid re-entrant loops)
    if (customers.length > 0) {
      setTimeout(saveFirebaseDBDirect, 1500);
    }
  } else {
    updateDBStatus();
    toast('❌ Failed to connect. Open browser console (F12) for details.', 'err');
  }
}

function clearFirebaseConfig() {
  if (!confirm('Clear Firebase config and disconnect from the cloud?')) return;
  localStorage.removeItem('firebase_config');
  closeM('m-fbsetup');
  toast('Disconnected from cloud.', 'inf');
  
  // Detach listener if any
  if (firebaseListener && typeof firebase !== 'undefined') {
    try {
      firebase.database().ref('calltrack').off('value', firebaseListener);
    } catch(e) {}
  }
  firebaseListener = null;
  
  isFirebaseInitialized = false;
  sharedDbAvailable = false;
  loadBrowserDB();
  renderAll();
}

function updateFirebaseStatusUI() {
  const statusEl = document.getElementById('fb-status');
  if (!statusEl) return;
  
  if (isFirebaseInitialized) {
    const config = getFirebaseConfig();
    statusEl.style.background = 'linear-gradient(135deg,#f0fdf4,#dcfce7)';
    statusEl.style.borderColor = '#bbf7d0';
    statusEl.innerHTML = `<span style="color:var(--green);font-weight:700;">● Cloud Connected</span><br>
      Connected to project: <strong>${config.projectId}</strong><br>
      <span style="color:var(--muted);font-size:12px;margin-top:4px;display:block;">All changes sync automatically to the cloud database in real-time.</span>`;
  } else {
    statusEl.style.background = 'linear-gradient(135deg,#fef2f2,#fff5f5)';
    statusEl.style.borderColor = '#fecaca';
    statusEl.innerHTML = `<span style="color:var(--red);font-weight:700;">● Running Offline (Local Mode)</span><br>
      Firebase is not configured. Data is saved only in this browser.<br>
      <span style="color:var(--muted);font-size:12px;margin-top:4px;display:block;">Configure Firebase above to enable sync across multiple PCs.</span>`;
  }
}

window.addEventListener('pagehide', function() {
  if (firebaseSaveTimer) {
    clearTimeout(firebaseSaveTimer);
    saveFirebaseDBDirect();
  }
});

// ===================== HELPERS =====================
function today() { return new Date().toISOString().slice(0,10); }
function thisYM() { const d = new Date(); return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0'); }
function fmtD(s) {
  if (!s) return '—';
  const [y,m,d] = s.split('-');
  return d + ' ' + ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][+m-1] + ' ' + y;
}

function lastCall(cid) {
  const logs = callLogs.filter(l => l.clientId === cid);
  if (!logs.length) return null;
  return logs.reduce((a, b) => a.date > b.date ? a : b);
}

function status(cid) {
  const lc = lastCall(cid);
  if (!lc) return 'never';
  if (lc.date.slice(0,7) === thisYM()) return 'called';
  const days = Math.floor((new Date() - new Date(lc.date)) / 86400000);
  return days > 30 ? 'overdue' : 'due';
}

function stats() {
  let called=0, overdue=0, due=0, never=0;
  customers.forEach(c => {
    const s = status(c.id);
    if (s==='called') called++;
    else if (s==='overdue') overdue++;
    else if (s==='due') due++;
    else never++;
  });
  const total = customers.length;
  const pct = total ? Math.round(called/total*100) : 0;
  return {total, called, overdue, due, never, pct};
}

function pendingFollowup(cid) {
  return callLogs.find(l => l.clientId===cid && l.followup && l.followup <= today());
}

function isNotInterested(cid) {
  const logs = callLogs.filter(l => l.clientId === cid);
  if (!logs.length) return false;
  const latest = logs.reduce((a, b) => a.date > b.date ? a : b);
  return latest.outcome === 'Not Interested';
}

// ===================== RENDER ALL =====================
function renderAll() {
  const s = stats();
  // Header stats
  document.getElementById('h1').textContent = s.total.toLocaleString();
  document.getElementById('h2').textContent = s.called;
  document.getElementById('h3').textContent = s.overdue + s.never;
  document.getElementById('h4').textContent = s.pct + '%';
  // Dashboard cards (only if visible)
  const dashOn = document.getElementById('tab-dash').classList.contains('on');
  if (dashOn) {
    document.getElementById('d-total').textContent = s.total.toLocaleString();
    document.getElementById('d-called').textContent = s.called;
    document.getElementById('d-bar').style.width = s.pct + '%';
    document.getElementById('d-over').textContent = s.overdue + s.never;
    document.getElementById('d-due').textContent = s.due;
    drawDashAlerts(s);
    drawMonthly();
  }
  // Only redraw active tab
  if (document.getElementById('tab-clients').classList.contains('on')) drawTable();
  if (document.getElementById('tab-alerts').classList.contains('on')) drawAlerts();
  if (document.getElementById('tab-calllog').classList.contains('on')) drawDailyLog();
  if (document.getElementById('tab-db').classList.contains('on')) updateDBStatus();
}

// ===================== DASHBOARD ALERTS =====================
function drawDashAlerts(s) {
  const td = today();
  // Today's follow-ups: followup date == today
  const todayFU = [];
  customers.forEach(c => {
    const logs = callLogs.filter(l => l.clientId === c.id && l.followup === td);
    logs.forEach(l => todayFU.push({customer: c, call: l}));
  });

  // Overdue follow-ups (past due, not today)
  const overdueFU = [];
  customers.forEach(c => {
    const logs = callLogs.filter(l => l.clientId === c.id && l.followup && l.followup < td);
    logs.forEach(l => overdueFU.push({customer: c, call: l}));
  });

  const ov = customers.filter(c => status(c.id) === 'overdue').slice(0, 5);

  let html = '';

  // TODAY'S FOLLOW-UPS — prominent section
  html += `<div class="st">📋 Today's Follow-ups — ${fmtD(td)}</div>`;
  if (todayFU.length) {
    todayFU.forEach(({customer: c, call: l}) => {
      html += `<div class="al warn" style="border-left-color:var(--accent)">
        <div class="al-t">
          <strong>${esc(c.name)}</strong>
          <span>📱 ${esc(c.mobile)} &nbsp;·&nbsp; Last outcome: ${esc(l.outcome)}</span>
          ${l.notes ? `<span style="display:block;margin-top:2px;font-style:italic">"${esc(l.notes)}"</span>` : ''}
        </div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button>
      </div>`;
    });
  } else {
    html += `<div class="al ok"><div class="al-t"><strong style="color:var(--green)">✅ No follow-ups scheduled for today</strong></div></div>`;
  }

  // OVERDUE FOLLOW-UPS
  if (overdueFU.length) {
    html += `<div class="st" style="margin-top:16px">⚠️ Overdue Follow-ups (${overdueFU.length})</div>`;
    overdueFU.slice(0, 5).forEach(({customer: c, call: l}) => {
      const days = Math.floor((new Date(td) - new Date(l.followup)) / 86400000);
      html += `<div class="al warn">
        <div class="al-t">
          <strong>${esc(c.name)}</strong>
          <span>Was due ${days} day${days!==1?'s':''} ago (${fmtD(l.followup)}) · ${esc(l.outcome)}</span>
        </div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button>
      </div>`;
    });
    if (overdueFU.length > 5) {
      html += `<div style="text-align:center;padding:8px;color:var(--muted);font-size:12px">...and ${overdueFU.length - 5} more overdue follow-ups. Check Alerts tab.</div>`;
    }
  }

  // OVERDUE CLIENTS (not called in 30+ days)
  if (ov.length) {
    html += `<div class="st" style="margin-top:16px">🚨 Not Called in 30+ Days</div>`;
    ov.forEach(c => {
      const lc = lastCall(c.id);
      const days = lc ? Math.floor((new Date() - new Date(lc.date)) / 86400000) : null;
      html += `<div class="al">
        <div class="al-t">
          <strong>${esc(c.name)}</strong>
          <span>${days ? days + ' days ago' : 'Never called'} · 📱 ${esc(c.mobile)}</span>
        </div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button>
      </div>`;
    });
    if (s.overdue + s.never > 5) {
      html += `<div style="text-align:center;padding:8px;color:var(--muted);font-size:12px">...and ${s.overdue + s.never - 5} more. Check Alerts tab.</div>`;
    }
  }

  document.getElementById('dash-alerts').innerHTML = html;
}

// ===================== MONTHLY CHART =====================
function drawMonthly() {
  const months = [];
  const now = new Date();
  // Start from April 2026
  const startYear = 2026, startMonth = 3; // April = index 3
  const curYear = now.getFullYear(), curMonth = now.getMonth();

  let y = startYear, m = startMonth;
  while (y < curYear || (y === curYear && m <= curMonth)) {
    const ym = y + '-' + String(m+1).padStart(2,'0');
    const label = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][m] + ' ' + y;
    const unique = new Set(callLogs.filter(l => l.date.slice(0,7) === ym).map(l => l.clientId)).size;
    const pct = customers.length ? Math.round(unique / customers.length * 100) : 0;
    const isCurrent = (y === curYear && m === curMonth);
    months.push({label, unique, pct, isCurrent});
    m++;
    if (m > 11) { m = 0; y++; }
  }

  const cols = Math.min(months.length, 6);
  let html = '<div class="st" style="margin-top:16px">📅 Monthly Call Progress (Apr 2026 onwards)</div>';
  html += `<div style="display:grid;grid-template-columns:repeat(${cols},1fr);gap:8px;margin-bottom:16px">`;
  months.forEach(mo => {
    html += `<div class="month-card ${mo.isCurrent ? 'current' : ''}">
      <div style="font-size:10px;color:${mo.isCurrent ? 'var(--accent)' : 'var(--muted)'};text-transform:uppercase;font-weight:600;letter-spacing:.5px">${mo.label}${mo.isCurrent ? ' ●' : ''}</div>
      <div style="font-size:24px;font-weight:700;margin:6px 0;color:var(--text)">${mo.unique}</div>
      <div style="font-size:11px;color:var(--muted)">${mo.pct}% covered</div>
      <div class="bar" style="margin-top:8px"><div class="bar-f" style="width:${mo.pct}%"></div></div>
    </div>`;
  });
  html += '</div>';
  document.getElementById('dash-monthly').innerHTML = html;
}

// ===================== TABLE =====================
function filteredData() {
  let data = customers.slice();
  // SEARCH — simple and reliable
  if (srchVal) {
    data = data.filter(c =>
      (c.name || '').toLowerCase().includes(srchVal) ||
      (c.mobile || '').toString().toLowerCase().includes(srchVal) ||
      (c.email || '').toLowerCase().includes(srchVal)
    );
  }
  // FILTER
  if (fltVal === 'notinterested') {
    data = data.filter(c => isNotInterested(c.id));
  } else if (fltVal) {
    data = data.filter(c => status(c.id) === fltVal);
  }
  // SORT
  data.sort((a, b) => {
    let av, bv;
    if (sortC === 'last') { av = (lastCall(a.id)||{date:'0000'}).date; bv = (lastCall(b.id)||{date:'0000'}).date; }
    else if (sortC === 'calls') { av = callLogs.filter(l=>l.clientId===a.id).length; bv = callLogs.filter(l=>l.clientId===b.id).length; }
    else { av = a.name; bv = b.name; }
    return av < bv ? -sortD : av > bv ? sortD : 0;
  });
  return data;
}

function drawTable() {
  const data = filteredData();
  const total = data.length;
  const pages = Math.ceil(total / PG) || 1;
  if (pg > pages) pg = pages;
  const start = (pg-1)*PG;
  const rows = data.slice(start, start+PG);

  // Count label
  document.getElementById('tbl-count').textContent =
    srchVal ? `${total} results for "${srchVal}"` : `${total} of ${customers.length} clients`;

  // Rows
  if (!rows.length) {
    document.getElementById('tbl-body').innerHTML = '<div class="empty"><div class="empty-i">🔍</div>No clients found</div>';
  } else {
    const s2col = {called:'b-g',due:'b-o',overdue:'b-r',never:'b-gray'};
    const s2lbl = {called:'✅ Called',due:'⏰ Due',overdue:'🚨 Overdue',never:'❌ Never'};
    const getBadge = (c, st) => {
      if (isNotInterested(c.id)) return ['b-r', '🚫 Not Interested'];
      return [s2col[st], s2lbl[st]];
    };
    document.getElementById('tbl-body').innerHTML =
      '<table><thead><tr>' +
      `<th onclick="srt('name')">Name${sortC==='name'?(sortD>0?' ▲':' ▼'):''}</th>` +
      '<th>Mobile</th><th>Email</th>' +
      `<th onclick="srt('last')">Last Call${sortC==='last'?(sortD>0?' ▲':' ▼'):''}</th>` +
      `<th onclick="srt('calls')">Calls${sortC==='calls'?(sortD>0?' ▲':' ▼'):''}</th>` +
      '<th>Status</th><th>Actions</th>' +
      '</tr></thead><tbody>' +
      rows.map(c => {
        const lc = lastCall(c.id);
        const st = status(c.id);
        const cnt = callLogs.filter(l=>l.clientId===c.id).length;
        const fu = pendingFollowup(c.id);
        return `<tr>
          <td style="font-weight:500">${esc(c.name)}${fu?'<span title="Follow-up pending" style="margin-left:5px;font-size:11px;color:var(--orange)">🔔</span>':''}</td>
          <td><a class="tel" href="tel:${esc(c.mobile)}">${esc(c.mobile)}</a></td>
          <td class="mono">${esc(c.email)}</td>
          <td class="mono">${lc?fmtD(lc.date):'—'}</td>
          <td style="text-align:center">${cnt}</td>
          <td><span class="badge ${getBadge(c,st)[0]}"><span class="dot"></span>${getBadge(c,st)[1]}</span></td>
          <td><div style="display:flex;gap:5px">
            <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Log</button>
            <button class="btn btn-g btn-s" onclick="openHist('${c.id}','${esc2(c.name)}')">📋 History</button>
            <button class="btn btn-g btn-s" onclick="openEditClient('${c.id}')">✏️ Edit</button>
            <button class="btn btn-s" style="background:#fee2e2;color:#dc2626;border:1px solid #fecaca" onclick="deleteClient('${c.id}','${esc2(c.name)}')">🗑️</button>
          </div></td>
        </tr>`;
      }).join('') +
      '</tbody></table>';
  }

  // Pagination
  let pgHtml = `<span class="pg-info">${total} clients · Page ${pg}/${pages}</span><div class="pg-btns">`;
  pgHtml += `<button class="pb" onclick="goP(${pg-1})" ${pg<=1?'disabled':''}>‹ Prev</button>`;
  const startP = Math.max(1, Math.min(pg-2, pages-4));
  const endP = Math.min(pages, startP+4);
  for (let i=startP; i<=endP; i++) {
    pgHtml += `<button class="pb${i===pg?' on':''}" onclick="goP(${i})">${i}</button>`;
  }
  pgHtml += `<button class="pb" onclick="goP(${pg+1})" ${pg>=pages?'disabled':''}>Next ›</button></div>`;
  document.getElementById('tbl-pg').innerHTML = pgHtml;
}

function srt(col) {
  if (sortC === col) sortD *= -1;
  else { sortC = col; sortD = 1; }
  drawTable();
}

function goP(p) {
  const pages = Math.ceil(filteredData().length / PG) || 1;
  if (p < 1 || p > pages) return;
  pg = p;
  drawTable();
}

// ===================== ALERTS TAB =====================
function drawAlerts() {
  const fu = customers.filter(c => pendingFollowup(c.id));
  const nv = customers.filter(c => status(c.id)==='never');
  const ov = customers.filter(c => status(c.id)==='overdue');
  let html = '';

  html += `<div class="st">🔔 Follow-ups Pending (${fu.length})</div>`;
  if (fu.length) {
    fu.forEach(c => {
      const f = pendingFollowup(c.id);
      html += `<div class="al warn"><div class="al-t"><strong>${esc(c.name)}</strong><span>Due: ${fmtD(f.followup)} · ${esc(f.outcome)} · ${esc(f.notes||'No notes')}</span></div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button></div>`;
    });
  } else html += '<div class="al ok"><div class="al-t"><strong style="color:var(--green)">✅ No pending follow-ups</strong></div></div>';

  html += `<div class="st" style="margin-top:18px">❌ Never Called (${nv.length})</div>`;
  if (nv.length) {
    nv.slice(0,30).forEach(c => {
      html += `<div class="al"><div class="al-t"><strong>${esc(c.name)}</strong><span>📱 ${esc(c.mobile)}</span></div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button></div>`;
    });
    if (nv.length > 30) html += `<div style="padding:10px;text-align:center;color:var(--muted);font-size:13px">...and ${nv.length-30} more. Go to Clients tab to see all.</div>`;
  } else html += '<div class="al ok"><div class="al-t"><strong style="color:var(--green)">✅ All clients have been called at least once!</strong></div></div>';

  html += `<div class="st" style="margin-top:18px">🚨 Overdue — Not called in 30+ days (${ov.length})</div>`;
  if (ov.length) {
    ov.slice(0,30).forEach(c => {
      const lc = lastCall(c.id);
      const days = Math.floor((new Date()-new Date(lc.date))/86400000);
      html += `<div class="al"><div class="al-t"><strong>${esc(c.name)}</strong><span>${days} days ago (${fmtD(lc.date)}) · 📱 ${esc(c.mobile)}</span></div>
        <button class="btn btn-p btn-s" onclick="openLog('${c.id}','${esc2(c.name)}')">📞 Call</button></div>`;
    });
    if (ov.length > 30) html += `<div style="padding:10px;text-align:center;color:var(--muted);font-size:13px">...and ${ov.length-30} more.</div>`;
  } else html += '<div class="al ok"><div class="al-t"><strong style="color:var(--green)">✅ No overdue clients!</strong></div></div>';

  document.getElementById('alerts-content').innerHTML = html;
}

// ===================== TABS =====================
function showTab(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.navbtn').forEach(b => b.classList.remove('on'));
  document.getElementById('tab-'+id).classList.add('on');
  const tabMap = {dash:0, clients:1, alerts:2, calllog:3, db:4};
  const navBtns = document.querySelectorAll('.navbtn');
  if (tabMap[id] !== undefined) navBtns[tabMap[id]].classList.add('on');
  if (id==='clients') drawTable();
  if (id==='alerts') drawAlerts();
  if (id==='db') updateDBStatus();
  if (id==='calllog') { setLogDate('today'); }
}

// ===================== LOG MODAL =====================
function openLog(cid, cname) {
  logCid = cid;
  document.getElementById('m-cname').textContent = cname;
  document.getElementById('l-date').value = today();
  document.getElementById('l-out').value = 'Completed';
  document.getElementById('l-fu').value = '';
  document.getElementById('l-notes').value = '';
  document.getElementById('m-log').classList.add('open');
}

function saveLog() {
  const date = document.getElementById('l-date').value;
  if (!date) { toast('Please select a date','err'); return; }
  const entry = {
    id: Date.now() + Math.random(),
    clientId: logCid,
    date,
    outcome: document.getElementById('l-out').value,
    followup: document.getElementById('l-fu').value || null,
    notes: document.getElementById('l-notes').value.trim(),
    createdAt: new Date().toISOString()
  };
  callLogs.push(entry);
  save();
  closeM('m-log');
  toast('✅ Call logged!','ok');
  renderAll();
}

// ===================== HISTORY MODAL =====================
function openHist(cid, cname) {
  histCid = cid;
  const c = customers.find(x=>x.id===cid);
  document.getElementById('mh-name').textContent = cname;
  document.getElementById('mh-info').textContent = `📱 ${c.mobile}  ·  ✉️ ${c.email}`;
  document.getElementById('mh-log-btn').onclick = () => { closeM('m-hist'); openLog(cid, cname); };
  renderHist(cid);
  document.getElementById('m-hist').classList.add('open');
}

function renderHist(cid) {
  const logs = callLogs.filter(l=>l.clientId===cid).sort((a,b)=>b.date.localeCompare(a.date));
  if (!logs.length) {
    document.getElementById('mh-entries').innerHTML = '<div class="empty"><div class="empty-i">📭</div>No calls logged yet</div>';
    return;
  }
  document.getElementById('mh-entries').innerHTML = logs.map(l => `
    <div class="he">
      <div class="heh">
        <span class="hed">${fmtD(l.date)}</span>
        <div style="display:flex;gap:6px;align-items:center">
          <span class="badge ${l.outcome==='Completed'?'b-g':l.outcome==='No Answer'?'b-gray':'b-o'}">${esc(l.outcome)}</span>
          <button class="hdel" onclick="delLog(${JSON.stringify(l.id)})">🗑️</button>
        </div>
      </div>
      ${l.followup?`<div style="font-size:12px;color:var(--orange);margin-bottom:4px">🔄 Follow-up: ${fmtD(l.followup)}</div>`:''}
      <div class="hen">${esc(l.notes||'No notes')}</div>
    </div>`).join('');
}

function delLog(id) {
  if (!confirm('Delete this call entry?')) return;
  callLogs = callLogs.filter(l => l.id !== id);
  save();
  renderHist(histCid);
  renderAll();
  toast('Entry deleted','inf');
}

function closeM(id) { document.getElementById(id).classList.remove('open'); }
document.addEventListener('click', e => { if(e.target.classList.contains('ov')) closeM(e.target.id); });

// ===================== DB SAVE/LOAD =====================
function saveDB() {
  const data = { version:1, exportedAt: new Date().toISOString(), customers, calls: callLogs };
  const blob = new Blob([JSON.stringify(data, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'calltrack_db.json';
  a.click();
  toast('✅ Database saved!','ok');
}

function dropDB(e) {
  e.preventDefault();
  document.getElementById('dropzone').classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if (f) readDBFile(f);
}

function loadDBFile(e) { if(e.target.files[0]) readDBFile(e.target.files[0]); }

function readDBFile(file) {
  const r = new FileReader();
  r.onload = e => {
    try {
      const d = JSON.parse(e.target.result);
      if (!d.customers || !d.calls) throw new Error('Invalid file');
      customers = d.customers;
      callLogs = d.calls;
      save();
      renderAll();
      toast(`✅ Loaded ${customers.length} customers & ${callLogs.length} call logs!`,'ok');
      updateDBStatus();
    } catch(err) {
      toast('❌ Invalid DB file. Please use a file exported from this app.','err');
    }
  };
  r.readAsText(file);
}

function updateDBStatus() {
  const el = document.getElementById('db-status');
  if (!el) return;
  const tm = thisYM();
  const calledThisMonth = new Set(callLogs.filter(l=>l.date.slice(0,7)===tm).map(l=>l.clientId)).size;
  
  let savePlace = '';
  if (isFirebaseInitialized) {
    savePlace = 'Data is synced in real-time to Firebase Cloud Database.';
  } else {
    savePlace = 'Data is saved locally in this browser. Configure Firebase to sync across PCs.';
  }
  
  el.innerHTML = `<strong>${customers.length}</strong> customers · <strong>${callLogs.length}</strong> total call entries · <strong>${calledThisMonth}</strong> called this month<br>
    <span style="color:var(--muted);font-size:12px;margin-top:4px;display:block">${savePlace} Use Download DB as an extra backup.</span>`;
    
  updateFirebaseStatusUI();
}

// ===================== IMPORT CUSTOMERS =====================
function dropCust(e) {
  e.preventDefault();
  document.getElementById('dropzone2').classList.remove('drag');
  const f = e.dataTransfer.files[0];
  if (f) readCustFile(f);
}
function loadCustFile(e) { if(e.target.files[0]) readCustFile(e.target.files[0]); }

function readCustFile(file) {
  const r = new FileReader();
  r.onload = e => {
    const text = e.target.result;
    const lines = text.split(/\r?\n/).filter(l=>l.trim());
    const hdrs = lines[0].split(',').map(h=>h.replace(/["\']/g,'').trim().toLowerCase());
    const ni = hdrs.findIndex(h=>h.includes('name')||h.includes('group'));
    const ei = hdrs.findIndex(h=>h.includes('email'));
    const mi = hdrs.findIndex(h=>h.includes('mobile')||h.includes('phone'));
    if (ni===-1) { toast('❌ Cannot find Name column','err'); return; }
    const existing = new Set(customers.map(c=>c.name.toLowerCase()));
    let added = 0;
    for (let i=1; i<lines.length; i++) {
      const cols = lines[i].split(',').map(c=>c.replace(/["\']/g,'').trim());
      const name = cols[ni];
      if (!name || existing.has(name.toLowerCase())) continue;
      customers.push({id:'ci'+Date.now()+i, name, email:ei>=0?cols[ei]:'', mobile:mi>=0?cols[mi]:''});
      added++;
    }
    save();
    renderAll();
    toast(`✅ Added ${added} new customers!`,'ok');
  };
  r.readAsText(file);
}

// ===================== EXPORT =====================
function exportCSV() {
  const data = filteredData();
  const rows = [['Name','Mobile','Email','Last Call','Total Calls','Status']];
  data.forEach(c => {
    const lc = lastCall(c.id);
    rows.push([c.name, c.mobile, c.email, lc?lc.date:'Never', callLogs.filter(l=>l.clientId===c.id).length, status(c.id)]);
  });
  const csv = rows.map(r=>r.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')).join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = 'clients_'+today()+'.csv';
  a.click();
  toast('📤 CSV exported!','ok');
}

function clearCalls() {
  if (!confirm('Delete ALL call logs? This cannot be undone.')) return;
  if (!confirm('Are you sure? All call history will be lost.')) return;
  callLogs = [];
  save();
  renderAll();
  toast('Call logs cleared','inf');
}

// ===================== UTILS =====================
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function esc2(s) { return String(s||'').replace(/\\/g,'\\\\').replace(/'/g,"&#39;"); }

function toast(msg, type='inf') {
  const t = document.createElement('div');
  t.className = 'toast '+type;
  t.textContent = msg;
  document.getElementById('toasts').appendChild(t);
  setTimeout(()=>t.remove(), 3200);
}

// ===================== DAILY CALL LOG =====================
function setLogDate(preset) {
  const inp = document.getElementById('log-date-filter');
  const now = new Date();
  if (preset === 'today') {
    inp.value = today();
    inp.dataset.mode = 'day';
  } else if (preset === 'yesterday') {
    const y = new Date(now); y.setDate(y.getDate()-1);
    inp.value = y.toISOString().slice(0,10);
    inp.dataset.mode = 'day';
  } else if (preset === 'week') {
    inp.value = today();
    inp.dataset.mode = 'week';
  } else if (preset === 'month') {
    inp.value = today();
    inp.dataset.mode = 'month';
  }
  drawDailyLog();
}

function drawDailyLog() {
  const inp = document.getElementById('log-date-filter');
  const selDate = inp.value;
  const mode = inp.dataset.mode || 'day';
  if (!selDate) return;

  // Determine date range
  let dateFrom, dateTo;
  if (mode === 'week') {
    const d = new Date(selDate);
    const day = d.getDay();
    const diff = d.getDate() - day + (day===0?-6:1);
    const mon = new Date(d.setDate(diff));
    const sun = new Date(mon); sun.setDate(mon.getDate()+6);
    dateFrom = mon.toISOString().slice(0,10);
    dateTo = sun.toISOString().slice(0,10);
  } else if (mode === 'month') {
    dateFrom = selDate.slice(0,7) + '-01';
    const last = new Date(+selDate.slice(0,4), +selDate.slice(5,7), 0);
    dateTo = last.toISOString().slice(0,10);
  } else {
    dateFrom = selDate;
    dateTo = selDate;
  }

  // Filter logs in range
  const logs = callLogs.filter(l => l.date >= dateFrom && l.date <= dateTo);

  // Summary cards
  const outcomes = {};
  logs.forEach(l => { outcomes[l.outcome] = (outcomes[l.outcome]||0)+1; });
  const uniqueClients = new Set(logs.map(l=>l.clientId)).size;
  const completed = logs.filter(l=>l.outcome==='Completed').length;
  const noAnswer = logs.filter(l=>l.outcome==='No Answer').length;
  const followups = logs.filter(l=>l.followup).length;

  const rangeLabel = mode==='day' ? fmtD(selDate) :
    mode==='week' ? `${fmtD(dateFrom)} — ${fmtD(dateTo)}` :
    selDate.slice(0,7);

  document.getElementById('daily-summary').innerHTML = `
    <div class="sc blue"><div class="sc-l">Total Calls</div><div class="sc-n">${logs.length}</div></div>
    <div class="sc green"><div class="sc-l">Completed</div><div class="sc-n">${completed}</div></div>
    <div class="sc red"><div class="sc-l">No Answer</div><div class="sc-n">${noAnswer}</div></div>
    <div class="sc orange"><div class="sc-l">Follow-ups Set</div><div class="sc-n">${followups}</div></div>
  `;

  if (!logs.length) {
    document.getElementById('daily-log-content').innerHTML = `
      <div class="empty"><div class="empty-i">📭</div>No calls logged for ${rangeLabel}</div>`;
    return;
  }

  // Group by date then list entries
  const byDate = {};
  logs.forEach(l => {
    if (!byDate[l.date]) byDate[l.date] = [];
    byDate[l.date].push(l);
  });
  const sortedDates = Object.keys(byDate).sort((a,b)=>b.localeCompare(a));

  let html = `<div style="margin-bottom:12px;font-size:13px;color:var(--muted)">${logs.length} call${logs.length!==1?'s':''} · ${uniqueClients} unique client${uniqueClients!==1?'s':''} · ${rangeLabel}</div>`;

  sortedDates.forEach(date => {
    const dayLogs = byDate[date].sort((a,b)=>b.createdAt?.localeCompare(a.createdAt||'')||0);
    html += `<div style="margin-bottom:20px">
      <div style="font-size:13px;font-weight:700;color:var(--accent);margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--border)">
        📅 ${fmtD(date)} <span style="font-weight:400;color:var(--muted);font-size:12px">(${dayLogs.length} call${dayLogs.length!==1?'s':''})</span>
      </div>`;
    dayLogs.forEach(l => {
      const cust = customers.find(c=>c.id===l.clientId);
      const outColor = l.outcome==='Completed'?'b-g':l.outcome==='No Answer'?'b-gray':'b-o';
      html += `<div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:12px 14px;margin-bottom:8px;display:flex;align-items:flex-start;gap:12px">
        <div style="flex:1;min-width:0">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px">
            <span style="font-weight:600">${esc(cust?cust.name:'Unknown')}</span>
            <span class="badge ${outColor}">${esc(l.outcome)}</span>
            ${l.followup?`<span style="font-size:11px;color:var(--orange)">🔄 Follow-up: ${fmtD(l.followup)}</span>`:''}
          </div>
          <div style="font-size:12px;color:var(--muted);margin-bottom:${l.notes?'4px':'0'}">
            📱 ${esc(cust?cust.mobile:'—')} &nbsp;·&nbsp; ✉️ ${esc(cust?cust.email:'—')}
          </div>
          ${l.notes?`<div style="font-size:13px;color:var(--text);background:var(--card2);border-radius:5px;padding:6px 10px;margin-top:6px">${esc(l.notes)}</div>`:''}
        </div>
        <button class="btn btn-p btn-s" style="flex-shrink:0" onclick="openLog('${l.clientId}','${esc2(cust?cust.name:'')}')">📞 Call Again</button>
      </div>`;
    });
    html += '</div>';
  });

  document.getElementById('daily-log-content').innerHTML = html;
}

function exportDailyCSV() {
  const inp = document.getElementById('log-date-filter');
  const selDate = inp.value;
  const mode = inp.dataset.mode || 'day';
  if (!selDate) { toast('Please select a date first','err'); return; }

  let dateFrom, dateTo;
  if (mode === 'week') {
    const d = new Date(selDate);
    const diff = d.getDate() - d.getDay() + (d.getDay()===0?-6:1);
    const mon = new Date(d.setDate(diff));
    const sun = new Date(mon); sun.setDate(mon.getDate()+6);
    dateFrom = mon.toISOString().slice(0,10);
    dateTo = sun.toISOString().slice(0,10);
  } else if (mode === 'month') {
    dateFrom = selDate.slice(0,7)+'-01';
    const last = new Date(+selDate.slice(0,4), +selDate.slice(5,7), 0);
    dateTo = last.toISOString().slice(0,10);
  } else { dateFrom = selDate; dateTo = selDate; }

  const logs = callLogs.filter(l => l.date >= dateFrom && l.date <= dateTo)
    .sort((a,b)=>b.date.localeCompare(a.date));

  const rows = [['Date','Client Name','Mobile','Email','Outcome','Follow-up Date','Notes']];
  logs.forEach(l => {
    const c = customers.find(x=>x.id===l.clientId);
    rows.push([l.date, c?c.name:'Unknown', c?c.mobile:'', c?c.email:'', l.outcome, l.followup||'', l.notes||'']);
  });
  const csv = rows.map(r=>r.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')).join('\n');  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = `calllog_${dateFrom}_${dateTo}.csv`;
  a.click();
  toast('📤 Call log exported!','ok');
}

// ===================== ADD / DELETE CLIENT =====================
function openAddClient() {
  document.getElementById('ac-name').value = '';
  document.getElementById('ac-mobile').value = '';
  document.getElementById('ac-email').value = '';
  document.getElementById('m-addclient').classList.add('open');
  setTimeout(() => document.getElementById('ac-name').focus(), 100);
}

function saveNewClient() {
  const name   = document.getElementById('ac-name').value.trim().toUpperCase();
  const mobile = document.getElementById('ac-mobile').value.trim();
  const email  = document.getElementById('ac-email').value.trim().toLowerCase();

  if (!name)   { toast('❌ Name is required', 'err'); return; }
  if (!mobile) { toast('❌ Mobile number is required', 'err'); return; }

  // Check duplicate
  const exists = customers.find(c => c.name === name || c.mobile === mobile);
  if (exists) { toast('❌ Client with same name or mobile already exists', 'err'); return; }

  const newClient = {
    id: 'c_' + Date.now() + '_' + Math.floor(Math.random()*10000),
    name, mobile, email
  };
  customers.push(newClient);
  save();
  closeM('m-addclient');
  toast('✅ Client added: ' + name, 'ok');
  pg = 1;
  srchVal = '';
  document.getElementById('srch').value = '';
  renderAll();
}

let editClientId = null;

function openEditClient(cid) {
  const c = customers.find(x => x.id === cid);
  if (!c) return;
  editClientId = cid;
  document.getElementById('ec-name').value   = c.name   || '';
  document.getElementById('ec-mobile').value = c.mobile || '';
  document.getElementById('ec-email').value  = c.email  || '';
  document.getElementById('ec-sub').textContent = 'Editing: ' + c.name;
  document.getElementById('m-editclient').classList.add('open');
  setTimeout(() => document.getElementById('ec-name').focus(), 100);
}

function saveEditClient() {
  const name   = document.getElementById('ec-name').value.trim().toUpperCase();
  const mobile = document.getElementById('ec-mobile').value.trim();
  const email  = document.getElementById('ec-email').value.trim().toLowerCase();

  if (!name)   { toast('❌ Name is required', 'err'); return; }
  if (!mobile) { toast('❌ Mobile number is required', 'err'); return; }

  // Check duplicate — allow same client but not another client with same name/mobile
  const duplicate = customers.find(c => c.id !== editClientId && (c.name === name || c.mobile === mobile));
  if (duplicate) { toast('❌ Another client already has this name or mobile', 'err'); return; }

  const idx = customers.findIndex(c => c.id === editClientId);
  if (idx === -1) { toast('❌ Client not found', 'err'); return; }

  customers[idx].name   = name;
  customers[idx].mobile = mobile;
  customers[idx].email  = email;

  save();
  closeM('m-editclient');
  toast('✅ Client updated: ' + name, 'ok');
  renderAll();
}

function deleteClient(cid, cname) {
  if (!confirm('Delete client: ' + cname + '?\nThis will also delete all their call history.')) return;
  customers = customers.filter(c => c.id !== cid);
  callLogs  = callLogs.filter(l => l.clientId !== cid);
  save();
  toast('🗑️ Client deleted: ' + cname, 'inf');
  renderAll();
}

// ===================== START =====================
function doSearch(val) {
  srchVal = (val || '').trim().toLowerCase();
  pg = 1;
  drawTable();
}

init();
</script>
<script>
// Force-clear old service worker cache so users always get latest files
if ('serviceWorker' in navigator && location.protocol !== 'file:') {
  window.addEventListener('load', () => {
    navigator.serviceWorker.getRegistrations().then(regs => {
      regs.forEach(r => r.unregister());
    });
  });
}
// Also delete any old Caches on startup
if ('caches' in window) {
  caches.keys().then(names => Promise.all(names.map(n => caches.delete(n))));
}
</script>
</body>
</html>
