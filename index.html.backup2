<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#2563eb">
<meta name="application-name" content="CallTrack CRM">
<link rel="manifest" href="manifest.webmanifest">
<!-- Firebase App and Realtime Database SDKs (v8) -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
<script src="firebase-config.js"></script>
<title>CallTrack CRM</title>
<style>
:root {
  --bg:       #f0f4f8;
  --card:     #ffffff;
  --card2:    #f7f9fc;
  --border:   #e2e8f0;
  --shadow:   0 2px 12px rgba(0,0,0,0.07);
  --shadow-lg:0 8px 30px rgba(0,0,0,0.10);

  --accent:   #2563eb;
  --accent-h: #1d4ed8;
  --accent-lt:#eff6ff;

  --green:    #16a34a;
  --green-lt: #f0fdf4;
  --red:      #dc2626;
  --red-lt:   #fef2f2;
  --orange:   #ea580c;
  --orange-lt:#fff7ed;
  --blue:     #2563eb;
  --blue-lt:  #eff6ff;
  --purple:   #7c3aed;
  --purple-lt:#f5f3ff;

  --text:     #1e293b;
  --text2:    #475569;
  --muted:    #94a3b8;
  --r:        10px;
}

* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:Segoe UI, Arial, sans-serif; font-size:14px; min-height:100vh; }

/* TOPBAR */
.topbar {
  background: linear-gradient(135deg, #1e40af 0%, #2563eb 50%, #3b82f6 100%);
  padding: 0 24px;
  height: 62px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky; top: 0; z-index: 50;
  box-shadow: 0 2px 16px rgba(37,99,235,0.3);
}
.logo { font-weight:700; font-size:18px; color:#fff; letter-spacing:-0.3px; display:flex; align-items:center; gap:8px; }
.logo span { opacity:0.85; font-weight:400; }
.hstats { display:flex; gap:24px; }
.hs { text-align:center; }
.hs-v { font-weight:700; font-size:18px; color:#fff; }
.hs-l { font-size:10px; color:rgba(255,255,255,0.7); text-transform:uppercase; letter-spacing:.6px; }

/* NAV */
.nav {
  background: #fff;
  border-bottom: 1px solid var(--border);
  display: flex;
  padding: 0 24px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
}
.navbtn {
  padding: 14px 20px;
  font-size: 13px; font-weight: 500;
  color: var(--text2);
  cursor: pointer;
  border: none; border-bottom: 3px solid transparent;
  background: none; font-family: inherit;
  transition: all .18s;
}
.navbtn:hover { color: var(--accent); background: var(--accent-lt); }
.navbtn.on { color: var(--accent); border-bottom-color: var(--accent); font-weight:600; }

/* PAGES */
.page { display:none; padding:24px; max-width:1400px; margin:0 auto; }
.page.on { display:block; }

/* STAT CARDS */
.sg { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:22px; }
.sc {
  background: var(--card);
  border-radius: 14px;
  padding: 20px;
  box-shadow: var(--shadow);
  border: 1px solid var(--border);
  position: relative; overflow: hidden;
}
.sc::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; border-radius:14px 14px 0 0; }
.sc.blue::before  { background: linear-gradient(90deg,#2563eb,#3b82f6); }
.sc.green::before { background: linear-gradient(90deg,#16a34a,#22c55e); }
.sc.red::before   { background: linear-gradient(90deg,#dc2626,#ef4444); }
.sc.orange::before{ background: linear-gradient(90deg,#ea580c,#f97316); }
.sc-icon { font-size:28px; margin-bottom:8px; }
.sc-n { font-size:30px; font-weight:700; color:var(--text); margin:4px 0 2px; }
.sc-l { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.6px; font-weight:500; }
.bar { height:5px; background:var(--border); border-radius:3px; margin-top:10px; overflow:hidden; }
.bar-f { height:100%; border-radius:3px; background:linear-gradient(90deg,#16a34a,#22c55e); transition:width .5s; }

/* SECTION TITLE */
.st { font-size:15px; font-weight:700; color:var(--text); margin-bottom:12px; margin-top:4px; display:flex; align-items:center; gap:8px; }

/* ALERT BOXES */
.al {
  background: var(--card);
  border: 1px solid var(--border);
  border-left: 4px solid var(--red);
  border-radius: var(--r);
  padding: 14px 16px;
  margin-bottom: 10px;
  display: flex; align-items: flex-start; gap:12px;
  box-shadow: var(--shadow);
}
.al.warn { border-left-color: var(--orange); }
.al.ok   { border-left-color: var(--green); background: var(--green-lt); border-color:#bbf7d0; }
.al-t { flex:1; font-size:13px; line-height:1.5; }
.al-t strong { display:block; font-weight:600; color:var(--text); margin-bottom:2px; }
.al-t span { color:var(--text2); font-size:12px; }

/* CONTROLS */
.ctrl { display:flex; gap:10px; margin-bottom:16px; flex-wrap:wrap; align-items:center; }
.sinp { position:relative; flex:1; min-width:240px; }
.sinp input {
  width:100%;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  padding: 10px 14px 10px 38px;
  color: var(--text);
  font-size: 13px; font-family:inherit;
  outline:none; transition:.18s;
  box-shadow: var(--shadow);
}
.sinp input:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(37,99,235,0.1); }
.sinp input::placeholder { color:var(--muted); }
.si { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted); pointer-events:none; font-size:15px; }

select {
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  padding: 10px 14px;
  color: var(--text);
  font-size: 13px; font-family:inherit;
  outline:none; cursor:pointer;
  box-shadow: var(--shadow);
  transition:.18s;
}
select:focus { border-color:var(--accent); }

/* BUTTONS */
.btn {
  padding: 9px 18px;
  border-radius: var(--r);
  border: none; cursor:pointer;
  font-size: 13px; font-weight: 500;
  font-family: inherit; transition:.18s;
  display: inline-flex; align-items:center; gap:5px;
}
.btn-p {
  background: linear-gradient(135deg,#2563eb,#3b82f6);
  color: #fff;
  box-shadow: 0 2px 8px rgba(37,99,235,0.3);
}
.btn-p:hover { background:linear-gradient(135deg,#1d4ed8,#2563eb); box-shadow:0 4px 14px rgba(37,99,235,0.4); transform:translateY(-1px); }
.btn-g {
  background: var(--card);
  border: 1.5px solid var(--border);
  color: var(--text2);
  box-shadow: var(--shadow);
}
.btn-g:hover { border-color:var(--accent); color:var(--accent); background:var(--accent-lt); }
.btn-s { padding:6px 12px; font-size:12px; border-radius:7px; }
.btn-danger { background:linear-gradient(135deg,#dc2626,#ef4444); color:#fff; box-shadow:0 2px 8px rgba(220,38,38,0.25); }
.btn-danger:hover { transform:translateY(-1px); }

/* TABLE */
.tw {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  box-shadow: var(--shadow);
}
.th {
  display: flex; justify-content:space-between; align-items:center;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--card2);
}
.th-t { font-weight:700; font-size:14px; color:var(--text); }
.th-c { font-size:12px; color:var(--muted); background:var(--accent-lt); color:var(--accent); padding:3px 10px; border-radius:20px; font-weight:500; }

table { width:100%; border-collapse:collapse; }
th {
  text-align:left; padding:10px 14px;
  font-size:11px; font-weight:600;
  text-transform:uppercase; letter-spacing:.6px;
  color:var(--muted); border-bottom:1px solid var(--border);
  background: var(--card2); cursor:pointer; user-select:none; white-space:nowrap;
}
th:hover { color:var(--accent); }
td { padding:11px 14px; border-bottom:1px solid var(--border); vertical-align:middle; color:var(--text); }
tr:last-child td { border-bottom:none; }
tr:hover td { background:#f8faff; }

/* BADGES */
.badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; }
.b-g    { background:var(--green-lt);  color:var(--green); border:1px solid #bbf7d0; }
.b-r    { background:var(--red-lt);    color:var(--red);   border:1px solid #fecaca; }
.b-o    { background:var(--orange-lt); color:var(--orange);border:1px solid #fed7aa; }
.b-gray { background:#f1f5f9;          color:var(--muted); border:1px solid var(--border); }
.dot { width:5px; height:5px; border-radius:50%; background:currentColor; }

.mono { font-family:Consolas, 'Courier New', monospace; font-size:12px; color:var(--text2); }
.tel { color:var(--accent); text-decoration:none; font-family:Consolas, 'Courier New', monospace; font-size:12px; font-weight:500; }
.tel:hover { color:var(--accent-h); text-decoration:underline; }

/* PAGINATION */
.pg { display:flex; justify-content:space-between; align-items:center; padding:12px 16px; border-top:1px solid var(--border); background:var(--card2); }
.pg-info { font-size:12px; color:var(--muted); }
.pg-btns { display:flex; gap:4px; }
.pb {
  padding:5px 11px; border-radius:7px;
  border:1.5px solid var(--border);
  background:var(--card); color:var(--text2);
  font-size:12px; cursor:pointer; font-family:inherit;
  transition:.15s;
}
.pb:hover { border-color:var(--accent); color:var(--accent); }
.pb.on { background:var(--accent); color:#fff; border-color:var(--accent); font-weight:600; }
.pb:disabled { opacity:.35; cursor:not-allowed; }

/* MODAL */
.ov {
  display:none; position:fixed; inset:0;
  background:rgba(15,23,42,0.5);
  z-index:200; align-items:center; justify-content:center;
  backdrop-filter:blur(4px);
}
.ov.open { display:flex; }
.modal {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 16px;
  width:92%; max-width:500px;
  max-height:90vh; overflow-y:auto;
  padding:28px;
  box-shadow: var(--shadow-lg);
  animation: su .22s ease;
}
@keyframes su { from{transform:translateY(18px);opacity:0} to{transform:none;opacity:1} }
.modal-t { font-size:18px; font-weight:700; color:var(--text); margin-bottom:4px; }
.modal-s { font-size:13px; color:var(--muted); margin-bottom:20px; }

.fg { margin-bottom:14px; }
.fg label { display:block; font-size:11px; color:var(--text2); margin-bottom:6px; text-transform:uppercase; letter-spacing:.5px; font-weight:600; }
.fg input, .fg select, .fg textarea {
  width:100%; background:var(--card2);
  border:1.5px solid var(--border); border-radius:8px;
  padding:10px 13px; color:var(--text);
  font-size:13px; font-family:inherit; outline:none; transition:.18s;
}
.fg input:focus, .fg select:focus, .fg textarea:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(37,99,235,0.08); }
.fg textarea { resize:vertical; min-height:76px; }
.mf { display:flex; gap:10px; justify-content:flex-end; margin-top:20px; padding-top:16px; border-top:1px solid var(--border); }

/* HISTORY ENTRIES */
.he { border:1px solid var(--border); border-radius:10px; padding:14px; margin-bottom:10px; background:var(--card2); }
.heh { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
.hed { font-family:Consolas, 'Courier New', monospace; font-size:12px; color:var(--accent); font-weight:500; }
.hen { font-size:13px; color:var(--text2); }
.hdel { background:none; border:none; color:var(--red); cursor:pointer; font-size:15px; padding:2px 4px; border-radius:4px; transition:.15s; }
.hdel:hover { background:var(--red-lt); }

/* UPLOAD ZONE */
.uz {
  border: 2px dashed var(--border);
  border-radius: 12px;
  padding: 36px; text-align:center;
  cursor:pointer; transition:.2s;
  margin-bottom:16px; background:var(--card);
}
.uz:hover, .uz.drag { border-color:var(--accent); background:var(--accent-lt); }
.uz-i { font-size:38px; margin-bottom:10px; }
.uz-t { font-weight:600; color:var(--text); margin-bottom:4px; }
.uz-s { font-size:12px; color:var(--muted); }

/* DB INFO BOX */
.db-info {
  background: linear-gradient(135deg,var(--accent-lt),#e0f2fe);
  border: 1px solid #bfdbfe;
  border-radius: 10px;
  padding: 16px 18px;
  margin-bottom:18px;
  font-size:13px; color:var(--text2);
}
.db-info strong { color:var(--accent); }

/* MONTHLY GRID CARD */
.month-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 10px; text-align:center;
  box-shadow: var(--shadow);
  transition:.2s;
}
.month-card:hover { box-shadow:var(--shadow-lg); transform:translateY(-2px); }
.month-card.current { border-color:var(--accent); background:var(--accent-lt); }

/* TOAST */
.toast {
  position:fixed; bottom:22px; right:22px; z-index:999;
  background:var(--card); border:1px solid var(--border);
  border-radius:12px; padding:13px 18px;
  font-size:13px; display:flex; align-items:center; gap:10px;
  animation:su .25s ease;
  box-shadow:var(--shadow-lg); max-width:320px; color:var(--text);
}
.toast.ok  { border-left:4px solid var(--green); }
.toast.err { border-left:4px solid var(--red); }
.toast.inf { border-left:4px solid var(--accent); }

/* EMPTY STATE */
.empty { text-align:center; padding:48px 20px; color:var(--muted); }
.empty-i { font-size:44px; margin-bottom:12px; }
.empty p { font-size:14px; }

/* SCROLLBAR */
::-webkit-scrollbar { width:6px; height:6px; }
::-webkit-scrollbar-track { background:var(--bg); }
::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }
::-webkit-scrollbar-thumb:hover { background:var(--muted); }

@media(max-width:768px) {
  .sg { grid-template-columns:repeat(2,1fr); }
  .hstats { display:none; }
  .page { padding:14px; }
  th:nth-child(3),td:nth-child(3),th:nth-child(4),td:nth-child(4) { display:none; }
  .nav { overflow-x:auto; -webkit-overflow-scrolling:touch; gap:0; }
  .navbtn { padding:12px 12px; font-size:12px; white-space:nowrap; flex-shrink:0; }
  .topbar .logo { font-size:15px; }
  .ctrl { flex-direction:column; }
  .sinp { min-width:100%; }
  select { width:100%; }
  .btn { width:100%; justify-content:center; }
  .tw { overflow-x:auto; }
  table { font-size:12px; }
  #daily-summary { grid-template-columns:repeat(2,1fr) !important; }
}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">📞 CallTrack CRM</div>
  <div class="hstats">
    <div class="hs"><div class="hs-v" id="h1">0</div><div class="hs-l">Total</div></div>
    <div class="hs"><div class="hs-v" id="h2">0</div><div class="hs-l">This Month</div></div>
    <div class="hs"><div class="hs-v" id="h3">0</div><div class="hs-l">Overdue</div></div>
    <div class="hs"><div class="hs-v" id="h4">0%</div><div class="hs-l">Progress</div></div>
  </div>
</div>

<div class="nav">
  <button class="navbtn on" onclick="showTab('dash')">📊 Dashboard</button>
  <button class="navbtn" onclick="showTab('clients')">👥 Clients</button>
  <button class="navbtn" onclick="showTab('alerts')">🔔 Alerts</button>
  <button class="navbtn" onclick="showTab('calllog')">📅 Daily Call Log</button>
  <button class="navbtn" onclick="showTab('db')">💾 Save / Load DB</button>
</div>

<!-- DASHBOARD -->
<div class="page on" id="tab-dash">
  <div class="sg">
    <div class="sc blue"><div class="sc-icon">👥</div><div class="sc-l">Total Clients</div><div class="sc-n" id="d-total">0</div></div>
    <div class="sc green"><div class="sc-icon">✅</div><div class="sc-l">Called This Month</div><div class="sc-n" id="d-called">0</div><div class="bar"><div class="bar-f" id="d-bar" style="width:0%"></div></div></div>
    <div class="sc red"><div class="sc-icon">🚨</div><div class="sc-l">Overdue / Never</div><div class="sc-n" id="d-over">0</div></div>
    <div class="sc orange"><div class="sc-icon">⏰</div><div class="sc-l">Due This Month</div><div class="sc-n" id="d-due">0</div></div>
  </div>
  <div id="dash-alerts"></div>
  <div id="dash-monthly"></div>
</div>

<!-- CLIENTS -->
<div class="page" id="tab-clients">
  <div class="ctrl">
    <div class="sinp">
      <span class="si">🔍</span>
      <input type="text" id="srch" placeholder="Type name, mobile or email to search..." autocomplete="off" spellcheck="false" oninput="doSearch(this.value)">
    </div>
    <select id="flt">
      <option value="">All Clients</option>
      <option value="called">✅ Called This Month</option>
      <option value="due">⏰ Due This Month</option>
      <option value="overdue">🚨 Overdue</option>
      <option value="never">❌ Never Called</option>
      <option value="notinterested">🚫 Not Interested</option>
    </select>
    <button class="btn btn-p" onclick="openAddClient()">➕ Add Client</button>
    <button class="btn btn-g" onclick="exportCSV()">📤 Export CSV</button>
  </div>
  <div class="tw">
    <div class="th">
      <span class="th-t">Customers</span>
      <span class="th-c" id="tbl-count"></span>
    </div>
    <div id="tbl-body"></div>
    <div class="pg" id="tbl-pg"></div>
  </div>
</div>

<!-- ALERTS -->
<div class="page" id="tab-alerts">
  <div id="alerts-content"></div>
</div>

<!-- DAILY CALL LOG -->
<div class="page" id="tab-calllog">
  <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:18px">
    <div>
      <label style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:5px">Select Date</label>
      <input type="date" id="log-date-filter" style="background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:9px 12px;color:var(--text);font-size:14px;font-family:inherit;outline:none;" oninput="drawDailyLog()">
    </div>
    <div style="margin-top:18px;display:flex;gap:8px">
      <button class="btn btn-g" onclick="setLogDate('today')">Today</button>
      <button class="btn btn-g" onclick="setLogDate('yesterday')">Yesterday</button>
      <button class="btn btn-g" onclick="setLogDate('week')">This Week</button>
      <button class="btn btn-g" onclick="setLogDate('month')">This Month</button>
    </div>
    <div style="margin-top:18px">
      <button class="btn btn-g" onclick="exportDailyCSV()">📤 Export CSV</button>
    </div>
  </div>
  <div id="daily-summary" style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px"></div>
  <div id="daily-log-content"></div>
</div>

<!-- DB SAVE/LOAD -->
<div class="page" id="tab-db">
  <div class="st">💾 Save Your Database</div>
  <div class="db-info" id="db-status">Loading...</div>
  <button class="btn btn-p" onclick="saveDB()" style="margin-bottom:24px">⬇️ Download DB File (calltrack_db.json)</button>

  <div class="st">☁️ Firebase Cloud Database Sync</div>
  <div class="db-info" id="fb-status" style="background: linear-gradient(135deg, #fef2f2, #fff5f5); border-color: #fecaca; margin-bottom: 12px;">
    Checking connection...
  </div>
  <button class="btn btn-p" onclick="openFirebaseSetup()" style="margin-bottom:24px">☁️ Configure Firebase</button>

  <div class="st">📂 Load Database</div>
  <div class="uz" id="dropzone" onclick="document.getElementById('dbfile').click()"
    ondragover="event.preventDefault();this.classList.add('drag')"
    ondragleave="this.classList.remove('drag')"
    ondrop="dropDB(event)">
    <div class="uz-i">📂</div>
    <div class="uz-t">Click to load a saved DB file</div>
    <div class="uz-s">Select the calltrack_db.json file you saved earlier</div>
  </div>
  <input type="file" id="dbfile" style="display:none" accept=".json" onchange="loadDBFile(event)">

  <div class="st" style="margin-top:24px">📥 Import New Customers (Excel/CSV)</div>
  <div class="uz" id="dropzone2" onclick="document.getElementById('custfile').click()"
    ondragover="event.preventDefault();this.classList.add('drag')"
    ondragleave="this.classList.remove('drag')"
    ondrop="dropCust(event)">
    <div class="uz-i">📋</div>
    <div class="uz-t">Upload customer Excel or CSV</div>
    <div class="uz-s">Columns: Name, Email, Mobile — call history preserved</div>
  </div>
  <input type="file" id="custfile" style="display:none" accept=".csv,.xlsx,.xls" onchange="loadCustFile(event)">

  <div style="margin-top:24px">
    <button class="btn btn-danger" onclick="clearCalls()">🗑️ Clear All Call Logs</button>
  </div>
</div>

<!-- ADD CLIENT MODAL -->
<div class="ov" id="m-addclient">
  <div class="modal">
    <div class="modal-t">➕ Add New Client</div>
    <div class="modal-s">Fill in the details below to add a new client</div>
    <div class="fg"><label>Full Name *</label><input type="text" id="ac-name" placeholder="e.g. RAJESH KUMAR SHARMA"></div>
    <div class="fg"><label>Mobile Number *</label><input type="tel" id="ac-mobile" placeholder="e.g. 9820012345"></div>
    <div class="fg"><label>Email Address</label><input type="email" id="ac-email" placeholder="e.g. rajesh@gmail.com"></div>
    <div class="mf">
      <button class="btn btn-g" onclick="closeM('m-addclient')">Cancel</button>
      <button class="btn btn-p" onclick="saveNewClient()">✅ Add Client</button>
    </div>
  </div>
</div>

<!-- EDIT CLIENT MODAL -->
<div class="ov" id="m-editclient">
  <div class="modal">
    <div class="modal-t">✏️ Edit Client</div>
    <div class="modal-s" id="ec-sub">Update client details below</div>
    <div class="fg"><label>Full Name *</label><input type="text" id="ec-name" placeholder="e.g. RAJESH KUMAR SHARMA"></div>
    <div class="fg"><label>Mobile Number *</label><input type="tel" id="ec-mobile" placeholder="e.g. 9820012345"></div>
    <div class="fg"><label>Email Address</label><input type="email" id="ec-email" placeholder="e.g. rajesh@gmail.com"></div>
    <div class="mf">
      <button class="btn btn-g" onclick="closeM('m-editclient')">Cancel</button>
      <button class="btn btn-p" onclick="saveEditClient()">💾 Save Changes</button>
    </div>
  </div>
</div>

<!-- LOG MODAL -->
<div class="ov" id="m-log">
  <div class="modal">
    <div class="modal-t">📞 Log a Call</div>
    <div class="modal-s" id="m-cname">—</div>
    <div class="fg"><label>Call Date</label><input type="date" id="l-date"></div>
    <div class="fg"><label>Outcome</label>
      <select id="l-out">
        <option value="Completed">✅ Completed — Spoke to client</option>
        <option value="No Answer">📵 No Answer</option>
        <option value="Callback Requested">🔄 Callback Requested</option>
        <option value="Voicemail Left">📬 Voicemail Left</option>
        <option value="Not Interested">🚫 Not Interested</option>
        <option value="Follow Up Needed">⚠️ Follow Up Needed</option>
      </select>
    </div>
    <div class="fg"><label>Follow-up Date (optional)</label><input type="date" id="l-fu"></div>
    <div class="fg"><label>Notes</label><textarea id="l-notes" placeholder="What was discussed..."></textarea></div>
    <div class="mf">
      <button class="btn btn-g" onclick="closeM('m-log')">Cancel</button>
      <button class="btn btn-p" onclick="saveLog()">💾 Save</button>
    </div>
  </div>
</div>

<!-- HISTORY MODAL -->
<div class="ov" id="m-hist">
  <div class="modal">
    <div class="modal-t" id="mh-name">History</div>
    <div class="modal-s" id="mh-info"></div>
    <div id="mh-entries"></div>
    <div class="mf">
      <button class="btn btn-g" onclick="closeM('m-hist')">Close</button>
      <button class="btn btn-p" id="mh-log-btn">📞 Log New Call</button>
    </div>
  </div>
</div>

<!-- FIREBASE SETUP MODAL -->
<div class="ov" id="m-fbsetup">
  <div class="modal" style="max-width: 550px;">
    <div class="modal-t">☁️ Configure Firebase Database</div>
    <div class="modal-s">Paste your Firebase Web App configuration object below.</div>
    <div class="fg">
      <label>Config JSON / Object Snippet</label>
      <textarea id="fb-config-text" style="height: 180px; font-family: monospace; font-size: 12px;" placeholder='{
  "apiKey": "AIzaSy...",
  "authDomain": "...",
  "databaseURL": "...",
  "projectId": "...",
  "storageBucket": "...",
  "messagingSenderId": "...",
  "appId": "..."
}'></textarea>
    </div>
    <div style="font-size:12px;color:var(--text2);margin-bottom:15px;line-height:1.4;">
      💡 <strong>Where to find this:</strong> Go to <a href="https://console.firebase.google.com" target="_blank" style="color:var(--accent);text-decoration:none;font-weight:600;">Firebase Console</a> &rarr; Project Settings &rarr; Your Apps (Web App) &rarr; Copy the config object.
    </div>
    <div class="mf">
      <button class="btn btn-g" onclick="closeM('m-fbsetup')">Cancel</button>
      <button class="btn btn-danger" onclick="clearFirebaseConfig()" style="margin-right: auto;">Clear Config</button>
      <button class="btn btn-p" onclick="saveFirebaseConfigUI()">💾 Save & Connect</button>
    </div>
  </div>
</div>

<div id="toasts"></div>

